{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ro'eh",
  "version": "0.1.0",
  "identifier": "fr.gir-lg.roeh",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Ro'eh",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": false,
        "resizable": true,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
